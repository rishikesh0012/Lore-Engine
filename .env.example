# ==========================================
# Lore Engine Environment Configuration
# ==========================================

# NVIDIA API Configuration
NVIDIA_API_KEY=nvapi-...

# Qdrant Vector Database
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Neo4j Graph Database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Relational Database (if used by app)
DATABASE_URL=postgresql://lore:password@postgres:5432/lore_engine
